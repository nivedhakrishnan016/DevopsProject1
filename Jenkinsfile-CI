pipeline {
    agent any

    environment {
        DOCKER_USERNAME = "nivedha16"
    }

    stages {

        stage("1. Cleanup") {
            steps {
                deleteDir()
            }
        }

        stage ('2. Git Checkout') {
            // use pipeline syntax generator to generate below step
            // 'Pipeline syntax' --> Steps 'Smaple step' --> git (enter url & branch & generate)
            steps {
                dir ("DevopsProject1"){
                  script {
                    git branch: 'main', url: 'https://github.com/nivedhakrishnan016/DevopsProject1.git' 
                  }
                }
            }
        } 

        stage("3. Maven Unit Test") {
            steps {
                dir("DevopsProject1") {
                    sh 'which mvn'
                    sh 'mvn -v'
                    sh 'mvn test'
                }
            }
        }

        stage('4. Maven Build') {
            steps {
                dir("DevopsProject1") {
                    sh 'mvn clean install'
                }
            }
        }

        stage("5. Maven Integration Test") {
            steps {
                dir("DevopsProject1") {
                    sh 'mvn verify'
                }
            }
        }

        stage('6. Docker Image Build') {
            steps {
                dir('DevopsProject1') {
                    script {
                        def JOB = env.JOB_NAME.toLowerCase()
                        sh "docker build -t ${JOB}:${BUILD_NUMBER} ."
                    }
                }
            }
        }

        stage('7. Docker Image Tag') {
            steps {
                dir('DevopsProject1') {
                    script {
                        def JOB = env.JOB_NAME.toLowerCase()
                        sh "docker tag ${JOB}:${BUILD_NUMBER} ${DOCKER_USERNAME}/${JOB}:v${BUILD_NUMBER}"
                        sh "docker tag ${JOB}:${BUILD_NUMBER} ${DOCKER_USERNAME}/${JOB}:latest"
                    }
                }
            }
        }

        stage('8. Trivy Image Scan') {
            steps {
                script {
                    def JOB = env.JOB_NAME.toLowerCase()
                    sh "trivy image ${DOCKER_USERNAME}/${JOB}:v${BUILD_NUMBER} > scan.txt"
                }
            }
        }

        stage('9. Docker Image Push') {
            steps {
                script {
                    withCredentials([usernamePassword(credentialsId: 'hub_creds', usernameVariable: 'docker_user', passwordVariable: 'docker_pass')]) {
                        sh "docker login -u '${docker_user}' -p '${docker_pass}'"
                        def JOB = env.JOB_NAME.toLowerCase()
                        sh "docker push ${DOCKER_USERNAME}/${JOB}:v${BUILD_NUMBER}"
                        sh "docker push ${DOCKER_USERNAME}/${JOB}:latest"
                    }
                }
            }
        }
    }
}
